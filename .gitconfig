[init]
	defaultBranch = main
[user]
	name = Josh Taylor
	username = joshbtay
	email = joshbtay@gmail.com
[push]
	autoSetupRemote = true
[alias]
	stashu = "!git stash push -S; git stash -u; git stash pop --index stash@{1}"
	stashi = "!git stash push -S"
; [core]
; 	pager = delta
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	dark = true

[merge]
	conflictStyle = zdiff3
